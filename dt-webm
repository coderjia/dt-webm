is_ip_or_cidr() {
  val="$1"
  if echo "${val}" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
    return 0
  fi
  if echo "${val}" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}/([0-9]|[1-2][0-9]|3[0-2])$'; then
    return 0
  fi
  return 1
}

ban_ip() {
  echo "请输入要封禁的 IP 或 CIDR："
  read -r target
  if ! is_ip_or_cidr "${target}"; then
    warn "格式非法，请输入正确的 IP/CIDR。"
    return
  fi
  show_exec_line "cscli decisions add --ip ${target} || cscli decisions add --range ${target}"
  cscli decisions add --ip "${target}" || cscli decisions add --range "${target}"
  if [ $? -eq 0 ]; then
    ok "封禁成功：${target}"
  else
    warn "封禁失败：${target}"
  fi
}

unban_ip() {
  tmpf="/tmp/dt-webm-decisions-$$.txt"
  show_exec_line "cscli decisions list"
  cscli decisions list > "${tmpf}" || true
  if ! grep -qE '([0-9]{1,3}\.){3}[0-9]{1,3}' "${tmpf}"; then
    warn "当前无封禁记录。"
    rm -f "${tmpf}"
    return
  fi
  echo "当前封禁列表："
  nl -w2 -s'. ' "${tmpf}"
  echo "请输入要解封的序号或直接输入 IP："
  read -r input
  target=""
  if echo "${input}" | grep -Eq '^[0-9]+$'; then
    target="$(sed -n "${input}p" "${tmpf}" | awk '{for(i=1;i<=NF;i++){if($i ~ /^([0-9]{1,3}\.){3}[0-9]{1,3}/){print $i;break}}}')"
  else
    target="${input}"
  fi
  rm -f "${tmpf}"
  if [ -z "${target}" ]; then
    warn "未解析到有效 IP。"
    return
  fi
  show_exec_line "cscli decisions delete --ip ${target}"
  cscli decisions delete --ip "${target}"
  if [ $? -eq 0 ]; then
    ok "解封成功：${target}"
  else
    warn "解封失败：${target}"
  fi
}

