        --time-format="%H:%M:%S %z" \
        --output="${out_html}" \
        ${lang_opt}
      ga_ret=$?
      set -e
    fi
  else
    if [ "${out_mode}" = "term" ]; then
      ga_cmd="slice_log_by_time ${mode} ${log_file} | goaccess - --log-format=COMBINED --date-format=%d/%b/%Y --time-format=%H:%M:%S"
      [ -n "${lang_opt}" ] && ga_cmd="${ga_cmd} ${lang_opt}"
      show_exec_line "${ga_cmd}"
      set +e
      slice_log_by_time "${mode}" "${log_file}" | goaccess - \
        --log-format=COMBINED \
        --date-format=%d/%b/%Y \
        --time-format=%H:%M:%S \
        ${lang_opt}
      ga_ret=$?
      set -e
    else
      ga_cmd="slice_log_by_time ${mode} ${log_file} | goaccess - --log-format=COMBINED --date-format=%d/%b/%Y --time-format=%H:%M:%S --output=${out_html}"
      [ -n "${lang_opt}" ] && ga_cmd="${ga_cmd} ${lang_opt}"
