}

install_webhook_script() {
  cat > "${WEBHOOK_SCRIPT}" <<'EOF'
#!/usr/bin/env bash
set -e
CONFIG_FILE="/etc/dt-webm/config.conf"
STATE_DIR="/var/lib/dt-webm"
STATE_FILE="${STATE_DIR}/webhook-state.db"
LOCK_FILE="${STATE_DIR}/webhook-state.lock"
[ -f "${CONFIG_FILE}" ] || exit 0
. "${CONFIG_FILE}" || true
[ -n "${WEBHOOK_URL:-}" ] || exit 0
mkdir -p "${STATE_DIR}"
touch "${STATE_FILE}"

if command -v flock >/dev/null 2>&1; then
  exec 9>"${LOCK_FILE}"
  flock -n 9 || exit 0
fi

ALERTS="$(cscli alerts list -o json 2>/dev/null || echo '[]')"
DECISIONS="$(cscli decisions list -o json 2>/dev/null || echo '[]')"

send_msg() {
  msg="$1"
  case "${WEBHOOK_TYPE:-}" in
    dingtalk|feishu)
      curl -sS -X POST "${WEBHOOK_URL}" \
        -H 'Content-Type: application/json' \
        -d "{\"msg_type\":\"text\",\"content\":{\"text\":\"${msg}\"}}" >/dev/null || true
      ;;
    telegram)
      curl -sS -X POST "${WEBHOOK_URL}" \
        -H 'Content-Type: application/json' \
        -d "{\"text\":\"${msg}\"}" >/dev/null || true
      ;;
    *)
      return 0
      ;;
  esac
}

is_sent() {
  sig="$1"
  grep -Fqx "${sig}" "${STATE_FILE}" 2>/dev/null
}

mark_sent() {
  sig="$1"
  echo "${sig}" >> "${STATE_FILE}"
}

# 仅推送未发送过的最新 20 条告警
echo "${ALERTS}" | jq -r '
  .[]? |
  "alert|\(.id // "na")|\(.source.ip // "unknown")|\(.scenario // "unknown")|\(.start_at // "na")|\(.country // "unknown")"
' | tail -n 20 | while IFS='|' read -r kind aid ip reason start_at country; do
  sig="${kind}|${aid}|${ip}|${reason}|${start_at}"
  if ! is_sent "${sig}"; then
    msg="CrowdSec 告警
IP: ${ip}
地区: ${country}
原因: ${reason}
时间: ${start_at}"
    send_msg "${msg}"
    mark_sent "${sig}"
  fi
done

# 仅推送未发送过的最新 20 条决策
echo "${DECISIONS}" | jq -r '
  .[]? |
  "decision|\(.id // "na")|\(.value // "unknown")|\(.scenario // "manual")|\(.created_at // "na")|\(.type // "unknown")"
' | tail -n 20 | while IFS='|' read -r kind did value scenario created_at dtype; do
  sig="${kind}|${did}|${value}|${scenario}|${created_at}"
  if ! is_sent "${sig}"; then
    msg="CrowdSec 决策
目标: ${value}
类型: ${dtype}
来源: ${scenario}
时间: ${created_at}"
    send_msg "${msg}"
    mark_sent "${sig}"
  fi
done

# 保留最近 2000 条，避免状态文件无限增长
tail -n 2000 "${STATE_FILE}" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "${STATE_FILE}"
EOF
  show_exec_line "chmod +x ${WEBHOOK_SCRIPT}"
  chmod +x "${WEBHOOK_SCRIPT}"
}

