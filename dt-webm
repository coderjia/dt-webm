  send_ok=0

  case "${WEBHOOK_TYPE:-}" in
    dingtalk)
      http_code="$(curl -sS -o "${resp_file}" -w '%{http_code}' -X POST "${WEBHOOK_URL}" \
        -H 'Content-Type: application/json' \
        -d "{\"msgtype\":\"text\",\"text\":{\"content\":\"${msg}\"}}" || true)"
      ;;
    feishu)
      http_code="$(curl -sS -o "${resp_file}" -w '%{http_code}' -X POST "${WEBHOOK_URL}" \
        -H 'Content-Type: application/json' \
        -d "{\"msg_type\":\"text\",\"content\":{\"text\":\"${msg}\"}}" || true)"
      ;;
    telegram)
      http_code="$(curl -sS -o "${resp_file}" -w '%{http_code}' -X POST "${WEBHOOK_URL}" \
        -H 'Content-Type: application/json' \
        -d "{\"text\":\"${msg}\"}" || true)"
      ;;
    *)
      rm -f "${resp_file}" >/dev/null 2>&1 || true
      return 0
      ;;
  esac

  resp_body="$(tr -d '\r\n' < "${resp_file}" 2>/dev/null || true)"
  [ -z "${resp_body}" ] && resp_body="(empty)"
  if [ "${WEBHOOK_TYPE:-}" = "dingtalk" ]; then
    # 钉钉成功通常为 {"errcode":0,"errmsg":"ok"}
    errcode="$(echo "${resp_body}" | jq -r '.errcode // empty' 2>/dev/null || true)"
    if [ "${http_code}" = "200" ] && [ "${errcode}" = "0" ]; then
      send_ok=1
    fi
    log "[调试] 钉钉响应 http=${http_code} errcode=${errcode:-unknown} body=${resp_body}"
  elif [ "${WEBHOOK_TYPE:-}" = "feishu" ]; then
    # 飞书成功常见 code/statusCode 为 0
    code="$(echo "${resp_body}" | jq -r '.code // .StatusCode // .statusCode // empty' 2>/dev/null || true)"
    if [ "${http_code}" = "200" ] && [ "${code}" = "0" ]; then
      send_ok=1
    fi
    log "[调试] 飞书响应 http=${http_code} code=${code:-unknown} body=${resp_body}"
  elif [ "${WEBHOOK_TYPE:-}" = "telegram" ]; then
    # Telegram Bot API 成功通常 ok=true
    tg_ok="$(echo "${resp_body}" | jq -r '.ok // empty' 2>/dev/null || true)"
    if [ "${http_code}" = "200" ] && [ "${tg_ok}" = "true" ]; then
      send_ok=1
    fi
    log "[调试] Telegram响应 http=${http_code} ok=${tg_ok:-unknown} body=${resp_body}"
  fi

  rm -f "${resp_file}" >/dev/null 2>&1 || true

  if [ "${send_ok}" -eq 1 ]; then
    return 0
  fi

  warn "Webhook 推送失败：type=${WEBHOOK_TYPE:-unknown}, http=${http_code:-unknown}"
  return 1
}

is_sent() {
  sig="$1"
  grep -Fqx "${sig}" "${STATE_FILE}" 2>/dev/null
}

mark_sent() {
  sig="$1"
  echo "${sig}" >> "${STATE_FILE}"
}

sent_count=0
skip_count=0
alert_new_count=0
decision_new_count=0

# 仅推送未发送过的最新 20 条告警
while IFS='|' read -r kind aid ip reason start_at country city; do
  sig="${kind}|${aid}|${ip}|${reason}|${start_at}"
  if ! is_sent "${sig}"; then
    if [ "${WEBHOOK_TYPE:-}" = "dingtalk" ]; then
      alert_new_count=$((alert_new_count + 1))
      echo "${sig}" >> "${pending_alert_sigs}"
      reason_cn="$(translate_scenario "${reason}")"
      cst_time="$(to_cst "${start_at}")"
      [ -z "${country}" ] && country="unknown"
      [ -z "${city}" ] && city="unknown"
      echo "- ${ip} | ${country}/${city} | ${reason_cn} | ${cst_time}" >> "${pending_alert_lines}"
      log "[聚合] 告警待发送：${sig}"
    else
      msg="CrowdSec 告警
IP: ${ip}
地区: ${country}
原因: ${reason}
时间: ${start_at}"
      if send_msg "${msg}"; then
        mark_sent "${sig}"
        sent_count=$((sent_count + 1))
        ok "告警已推送：IP=${ip} 场景=${reason}"
      else
        warn "告警推送失败：IP=${ip} 场景=${reason}"
      fi
    fi
  else
    skip_count=$((skip_count + 1))
    log "[跳过] 告警已推送过：${sig}"
  fi
done < <(
  echo "${ALERTS}" | jq -r '
    .[]? |
    "alert|\(.id // "na")|\(.source.ip // "unknown")|\(.scenario // "unknown")|\(.start_at // "na")|\(.country // "unknown")|\(.city // "unknown")"
  ' | tail -n 20
)

# 仅推送未发送过的最新 20 条决策
while IFS='|' read -r kind did value scenario created_at dtype; do
  sig="${kind}|${did}|${value}|${scenario}|${created_at}"
  if ! is_sent "${sig}"; then
    if [ "${WEBHOOK_TYPE:-}" = "dingtalk" ]; then
      decision_new_count=$((decision_new_count + 1))
      echo "${sig}" >> "${pending_decision_sigs}"
      scenario_cn="$(translate_scenario "${scenario}")"
      cst_time="$(to_cst "${created_at}")"
      echo "- ${value} | ${scenario_cn} | ${cst_time}" >> "${pending_decision_lines}"
      log "[聚合] 决策待发送：${sig}"
    else
      msg="CrowdSec 决策
目标: ${value}
类型: ${dtype}
来源: ${scenario}
时间: ${created_at}"
      if send_msg "${msg}"; then
        mark_sent "${sig}"
        sent_count=$((sent_count + 1))
        ok "决策已推送：目标=${value} 来源=${scenario}"
      else
        warn "决策推送失败：目标=${value} 来源=${scenario}"
      fi
    fi
  else
    skip_count=$((skip_count + 1))
    log "[跳过] 决策已推送过：${sig}"
  fi
done < <(
  echo "${DECISIONS}" | jq -r '
    .[]? |
    "decision|\(.id // "na")|\(.value // .scope.value // .source.ip // "unknown")|\(.scenario // "manual")|\(.created_at // "na")|\(.type // "unknown")"
  ' | tail -n 20
)

# 钉钉自动聚合摘要：每轮最多 2 条消息（告警摘要 + 决策摘要），避免 660026 限流
if [ "${WEBHOOK_TYPE:-}" = "dingtalk" ]; then
  if [ "${alert_new_count}" -gt 0 ]; then
    alert_preview="$(head -n 10 "${pending_alert_lines}" 2>/dev/null || true)"
    cst_now="$(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S')"
    alert_msg="服务器安全通报(CrowdSec)
时间(东八区): ${cst_now}
本轮新增: ${alert_new_count} 条
前10条告警(服务器查看更多):
${alert_preview}"
    if send_msg "${alert_msg}"; then
      while IFS= read -r sig; do
        [ -n "${sig}" ] && mark_sent "${sig}"
      done < "${pending_alert_sigs}"
      sent_count=$((sent_count + alert_new_count))
      ok "钉钉告警摘要已推送：本轮 ${alert_new_count} 条。"
    else
      warn "钉钉告警摘要推送失败：本轮 ${alert_new_count} 条未标记已发送。"
    fi
  fi

  if [ "${decision_new_count}" -gt 0 ]; then
    decision_preview="$(head -n 10 "${pending_decision_lines}" 2>/dev/null || true)"
    cst_now="$(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S')"
    decision_msg="CrowdSec 决策摘要
时间(东八区): ${cst_now}
本轮新增: ${decision_new_count} 条
前10条决策(服务器查看更多):
${decision_preview}"
    if send_msg "${decision_msg}"; then
      while IFS= read -r sig; do
        [ -n "${sig}" ] && mark_sent "${sig}"
      done < "${pending_decision_sigs}"
      sent_count=$((sent_count + decision_new_count))
      ok "钉钉决策摘要已推送：本轮 ${decision_new_count} 条。"
    else
      warn "钉钉决策摘要推送失败：本轮 ${decision_new_count} 条未标记已发送。"
    fi
  fi
fi

# 保留最近 2000 条，避免状态文件无限增长
tail -n 2000 "${STATE_FILE}" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "${STATE_FILE}"
rm -f "${pending_alert_sigs}" "${pending_alert_lines}" "${pending_decision_sigs}" "${pending_decision_lines}" >/dev/null 2>&1 || true
ok "执行结束：新增推送=${sent_count}，去重跳过=${skip_count}，日志=${LOG_FILE}"
EOF
  show_exec_line "chmod +x ${WEBHOOK_SCRIPT}"
  chmod +x "${WEBHOOK_SCRIPT}"
}

setup_alert_push_cron() {
  load_config
  interval_min="${WEBHOOK_PUSH_INTERVAL_MINUTES:-1440}"
  install_webhook_script
  tmpc="/tmp/dt-webm-cron-$$.txt"
  show_exec_line "crontab（写入）* * * * * ${WEBHOOK_SCRIPT} ${CRON_ALERT_MARK}（实际推送间隔由 WEBHOOK_PUSH_INTERVAL_MINUTES=${interval_min} 控制）"
  crontab -l 2>/dev/null | grep -v "${CRON_ALERT_MARK}" > "${tmpc}" || true
  echo "* * * * * ${WEBHOOK_SCRIPT} ${CRON_ALERT_MARK}" >> "${tmpc}"
  crontab "${tmpc}"
  rm -f "${tmpc}"
  ok "已配置告警推送定时任务（每 1 分钟触发，默认每 ${interval_min} 分钟真正推送一次）。"
}

update_geoip_db() {
  load_config
  mkdir -p /var/lib/dt-webm
  db_file="/var/lib/dt-webm/geoip.mmdb"

  if [ -n "${GEOIP_URL:-}" ]; then
    show_exec_line "curl -fsSL \"\${GEOIP_URL}\" -o ${db_file}"
    curl -fsSL "${GEOIP_URL}" -o "${db_file}"
  else
    warn "未配置 GEOIP_URL，无法自动下载。请在配置文件中添加 GEOIP_URL。"
    return
  fi

  if [ $? -eq 0 ]; then
    ok "GeoIP 数据库更新成功：${db_file}"
  else
    warn "GeoIP 更新失败。"
  fi
}

setup_geoip_cron() {
  tmpc="/tmp/dt-webm-geoip-cron-$$.txt"
  show_exec_line "crontab（写入）0 3 1 * * /usr/local/bin/dt-webm geoip-update ${CRON_GEOIP_MARK}"
  crontab -l 2>/dev/null | grep -v "${CRON_GEOIP_MARK}" > "${tmpc}" || true
  echo "0 3 1 * * /usr/local/bin/dt-webm geoip-update ${CRON_GEOIP_MARK}" >> "${tmpc}"
  crontab "${tmpc}"
  rm -f "${tmpc}"
  ok "已配置 GeoIP 月度更新任务（每月 1 日 03:00）。"
}

# 从远程拉取最新 dt-webm 覆盖当前正在使用的脚本文件（需确认）
self_update_dt_webm() {
  title "程序自更新"
  if ! check_cmd curl; then
    warn "未检测到 curl，无法自更新。"
    return 1
  fi

  local target
  target="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
  if [ -z "${target}" ] || [ ! -f "${target}" ]; then
    warn "无法解析当前脚本路径。"
    return 1
  fi

  source_name="GitHub"
  source_url="${REMOTE_DT_WEBM_URL_GITHUB}"
  if [ -r /dev/tty ]; then
    echo "请选择更新源：" > /dev/tty
    echo "1) GitHub（默认）" > /dev/tty
    echo "2) Gitee（中国大陆网络受限可选）" > /dev/tty
    echo "请输入序号 [1/2]：" > /dev/tty
    read -r src_sel < /dev/tty
  else
    echo "请选择更新源："
    echo "1) GitHub（默认）"
    echo "2) Gitee（中国大陆网络受限可选）"
    echo "请输入序号 [1/2]："
    read -r src_sel
  fi
  case "${src_sel:-1}" in
    2)
      source_name="Gitee"
      source_url="${REMOTE_DT_WEBM_URL_GITEE}"
      ;;
    *)
      source_name="GitHub"
      source_url="${REMOTE_DT_WEBM_URL_GITHUB}"
      ;;
  esac

  info "更新源：${source_name}"
  info "远程地址：${source_url}"
  info "将覆盖本地文件：${target}"
  info "确认执行自更新？(y/n)"
  if [ -r /dev/tty ]; then
    read -r ans < /dev/tty
  else
    read -r ans
  fi
  if [ "${ans}" != "y" ]; then
    info "已取消自更新。"
    return 0
  fi

  if [ ! -w "${target}" ] && [ "$(id -u)" -ne 0 ]; then
    warn "目标文件不可写：${target}"
    warn "请使用 root 执行，例如：sudo dt-webm self-update"
    return 1
  fi

  tmp_file="$(mktemp /tmp/dt-webm-self-update.XXXXXX)"
  show_exec_line "curl -fSL ${source_url} -o ${tmp_file}（含超时与重试）"
  info "正在下载，请稍候…"
  if ! curl -fSL \
    --connect-timeout 8 \
    --max-time 60 \
    --retry 3 \
    --retry-delay 2 \
    --retry-connrefused \
    "${source_url}" -o "${tmp_file}"; then
    warn "下载失败，请检查网络或稍后重试。"
    warn "可手工验证：curl -I ${source_url}"
    rm -f "${tmp_file}"
    return 1
  fi

  if [ ! -s "${tmp_file}" ]; then
    warn "下载内容为空，已中止。"
    rm -f "${tmp_file}"
    return 1
  fi

  if ! head -n 1 "${tmp_file}" | grep -q '^#!'; then
    warn "下载内容不是合法脚本（缺少 shebang），已中止。"
    rm -f "${tmp_file}"
    return 1
  fi

  show_exec_line "cp -f ${tmp_file} ${target} && chmod 0755 ${target}"
  cp -f "${tmp_file}" "${target}"
  chmod 0755 "${target}"
  rm -f "${tmp_file}"

  ok "自更新完成：${target}"
  info "请重新运行 dt-webm 以加载新版本。"
}

do_install_cmd() {
  require_root
  script_abs="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
  show_exec_line "ln -sf ${script_abs} /usr/local/bin/dt-webm"
  ln -sf "${script_abs}" /usr/local/bin/dt-webm
  if [ $? -eq 0 ]; then
    ok "已注册全局命令：/usr/local/bin/dt-webm -> ${script_abs}"
  fi

  detect_pkg_mgr
  prompt_install_dependencies
  log_dir="$(discover_log_dir)"
  set_log_acl "${log_dir}"
  setup_geoip_cron
  setup_alert_push_cron

  load_config
  ports="${ALLOW_PORTS:-22,80,443}"
  info "请确认防火墙已放行端口：${ports}。"
}

show_main_menu() {
  title "dt-webm 轻量服务器安全管理"
  echo "1) 依赖检查与安装"
  echo "2) GoAccess 日志统计"
  echo "3) CrowdSec 攻击警报"
  echo "4) CrowdSec 运行指标"
  echo "5) CrowdSec 封禁管理"
  echo "6) Webhook 推送配置(钉钉/飞书/Telegram)"
  echo "7) 端口白名单配置"
  echo "8) 更新 GeoIP 数据库"
  echo "9) 添加 GeoIP 更新任务(crontab)"
  echo "10) 配置告警推送任务"
  echo "11) 安装全局命令（install）"
  echo "12) 更新"
  echo "0) 退出"
  echo "请输入序号："
}

main() {
  detect_pkg_mgr
  ensure_config
  ensure_default_config_values

  case "${1:-}" in
    install) do_install_cmd; exit 0 ;;
    geoip-update) update_geoip_db; exit 0 ;;
    metrics) show_cscli_metrics; exit 0 ;;
    self-update) self_update_dt_webm; exit 0 ;;
    "")
      :
      ;;
    *)
      warn "未知命令：$1"
      echo "用法：dt-webm [install|geoip-update|metrics|self-update]"
      exit 1
      ;;
  esac

  while true; do
    show_main_menu
    read -r sel
    case "${sel}" in
      1) prompt_install_dependencies ;;
      2) goaccess_report ;;
      3) show_alerts ;;
      4) show_cscli_metrics ;;
      5) manage_decisions ;;
      6) configure_webhook ;;
      7) configure_allow_ports ;;
      8) update_geoip_db ;;
      9) setup_geoip_cron ;;
      10) setup_alert_push_cron ;;
      11) do_install_cmd ;;
      12) self_update_dt_webm ;;
      0) ok "已退出。"; exit 0 ;;
      *) warn "无效选择，请重试。" ;;
    esac
    echo
  done
}

main "$@"
