#!/usr/bin/env bash
set -e

# =========================
# dt-webm: GoAccess + CrowdSec
# =========================

SCRIPT_NAME="dt-webm"
CONFIG_DIR="/etc/dt-webm"
CONFIG_FILE="${CONFIG_DIR}/config.conf"
WEBHOOK_SCRIPT="/usr/local/bin/dt-webm-webhook.sh"
CRON_GEOIP_MARK="# dt-webm-geoip-update"
CRON_ALERT_MARK="# dt-webm-alert-push"

# 自更新源：GitHub / Gitee（二选一）
REPO_RAW_BASE_GITHUB="https://raw.githubusercontent.com/coderjia/dt-webm/main"
REPO_RAW_BASE_GITEE="https://gitee.com/coderjia/dt-webm/raw/main"
REMOTE_DT_WEBM_URL_GITHUB="${REPO_RAW_BASE_GITHUB}/dt-webm"
REMOTE_DT_WEBM_URL_GITEE="${REPO_RAW_BASE_GITEE}/dt-webm"

# GoAccess：与 NPM 官方 log_format 对齐（见镜像内 /etc/nginx/conf.d/include/log-proxy.conf）
# proxy:  [$time_local] $upstream_cache_status $upstream_status $status - $request_method ...
# standard: [$time_local] $status - $request_method ...（无 upstream 两段，无 [Sent-to]）
# 行首时间戳内时区由 %^ 吸收，故 --time-format 仅含时分秒，勿再带 %z
# %v=Host，%h=[Client …] 内 IP；整段单引号赋值避免 shell 误解析 [] / ""
GOACCESS_NPM_LOG_FORMAT='[%d:%t %^] %^ %^ %s - %m %^ %v "%U" [Client %h] [Length %b] [Gzip %^] [Sent-to %^] "%u" "%R"'
GOACCESS_NPM_LOG_FORMAT_ALT='[%d:%t %^] %s - %m %^ %v "%U" [Client %h] [Length %b] [Gzip %^] "%u" "%R"'

COLOR_RED='\033[0;31m'
COLOR_GREEN='\033[0;32m'
COLOR_BLUE='\033[0;34m'
COLOR_YELLOW='\033[1;33m'
COLOR_RESET='\033[0m'

title() { echo -e "${COLOR_BLUE}==== $* ====${COLOR_RESET}"; }
ok() { echo -e "${COLOR_GREEN}[成功]${COLOR_RESET} $*"; }
warn() { echo -e "${COLOR_RED}[警告]${COLOR_RESET} $*"; }
info() { echo -e "${COLOR_YELLOW}[提示]${COLOR_RESET} $*"; }

# 执行外部命令前输出等效命令行，便于核对、审计与复制
show_exec_line() {
  info "将执行：$*"
}

require_root() {
  if [ "$(id -u)" -ne 0 ]; then
    warn "此操作需要 root 权限，请使用 sudo 或 root 用户执行。"
    exit 1
  fi
}

detect_pkg_mgr() {
  if command -v apt >/dev/null 2>&1; then
    PKG_MGR="apt"
    OS_FAMILY="debian"
  elif command -v dnf >/dev/null 2>&1; then
    PKG_MGR="dnf"
    OS_FAMILY="rhel"
  elif command -v yum >/dev/null 2>&1; then
    PKG_MGR="yum"
    OS_FAMILY="rhel"
  else
    warn "未检测到支持的包管理器（apt/dnf/yum）。"
    exit 1
  fi
}

ensure_config() {
  mkdir -p "${CONFIG_DIR}"
  if [ ! -f "${CONFIG_FILE}" ]; then
    cat > "${CONFIG_FILE}" <<'EOF'
# dt-webm 配置文件
# Web 日志目录（自动发现失败时可手工配置）
LOG_DIR=""
# Webhook 类型：dingtalk / feishu / telegram
WEBHOOK_TYPE=""
# Webhook URL
WEBHOOK_URL=""
# Webhook 推送间隔（分钟，默认 1440 = 24 小时）
WEBHOOK_PUSH_INTERVAL_MINUTES="1440"
# GeoIP 数据库下载地址（支持 DB-IP 或 MaxMind 链接）
GEOIP_URL=""
# GoAccess 界面语言：zh_CN/zh 等表示使用简体中文（运行时注入 LANG/LC_ALL=zh_CN.UTF-8，需系统有该 locale）
GOACCESS_LANG="zh_CN"
# 防火墙建议放行端口（逗号分隔）
ALLOW_PORTS="22,80,443"
EOF
  fi
}

load_config() {
  ensure_config
  # shellcheck disable=SC1090
  . "${CONFIG_FILE}" || true
}

save_kv() {
  key="$1"
  val="$2"
  ensure_config
  if grep -q "^${key}=" "${CONFIG_FILE}" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=\"${val}\"|g" "${CONFIG_FILE}"
  else
    echo "${key}=\"${val}\"" >> "${CONFIG_FILE}"
  fi
}

ensure_default_config_values() {
  # 兼容老版本 config.conf 缺少关键键值
  if ! grep -q '^ALLOW_PORTS=' "${CONFIG_FILE}" 2>/dev/null; then
    echo 'ALLOW_PORTS="22,80,443"' >> "${CONFIG_FILE}"
  fi
  if ! grep -q '^GOACCESS_LANG=' "${CONFIG_FILE}" 2>/dev/null; then
    echo 'GOACCESS_LANG="zh_CN"' >> "${CONFIG_FILE}"
  fi
  if ! grep -q '^WEBHOOK_PUSH_INTERVAL_MINUTES=' "${CONFIG_FILE}" 2>/dev/null; then
    echo 'WEBHOOK_PUSH_INTERVAL_MINUTES="1440"' >> "${CONFIG_FILE}"
  fi
}

check_cmd() {
  command -v "$1" >/dev/null 2>&1
}

get_ssh_ip() {
  ip_from_conn="$(echo "${SSH_CONNECTION:-}" | awk '{print $1}')"
  if [ -n "${ip_from_conn}" ]; then
    echo "${ip_from_conn}"
    return
  fi
  who_ip="$(who | awk 'NR==1{gsub(/[()]/,"",$5);print $5}')"
  echo "${who_ip:-}"
}

whitelist_self_ip() {
  ssh_ip="$(get_ssh_ip)"
  if [ -z "${ssh_ip}" ]; then
    info "未检测到当前 SSH 登录 IP，跳过自杀保护白名单。"
    return
  fi

  if ! check_cmd cscli; then
    warn "未检测到 cscli，无法写入 CrowdSec 白名单。"
    return
  fi

  title "写入自杀保护白名单"
  show_exec_line "cscli parsers add crowdsecurity/whitelists"
  if cscli parsers add crowdsecurity/whitelists >/dev/null 2>&1 || true; then
    :
  fi

  mkdir -p /etc/crowdsec/parsers/s02-enrich/
  wl_file="/etc/crowdsec/parsers/s02-enrich/dt-webm-whitelist.yaml"
  show_exec_line "cat > ${wl_file}（写入当前 SSH IP 白名单）"
  cat > "${wl_file}" <<EOF
name: dt-webm/self-whitelist
description: "dt-webm 自动白名单"
whitelist:
  reason: "当前 SSH 登录 IP 防误封"
  ip:
    - "${ssh_ip}"
EOF
  if [ $? -eq 0 ]; then
    ok "已将 ${ssh_ip} 写入 CrowdSec 白名单配置。"
    show_exec_line "systemctl restart crowdsec"
    systemctl restart crowdsec >/dev/null 2>&1 || true
  else
    warn "白名单写入失败。"
  fi
}

set_log_acl() {
  log_dir="$1"
  if [ -z "${log_dir}" ] || [ ! -d "${log_dir}" ]; then
    warn "日志目录不存在，跳过 ACL 配置。"
    return
  fi
  if ! check_cmd setfacl; then
    info "未检测到 setfacl，尝试安装 acl。"
    if [ "${PKG_MGR}" = "apt" ]; then
      apt update && apt install -y acl
    else
      ${PKG_MGR} install -y acl
    fi
  fi
  show_exec_line "setfacl -R -m u:crowdsec:rx ${log_dir} && setfacl -R -d -m u:crowdsec:rx ${log_dir}"
  setfacl -R -m u:crowdsec:rx "${log_dir}" || true
  setfacl -R -d -m u:crowdsec:rx "${log_dir}" || true
  if [ $? -eq 0 ]; then
    ok "已为 crowdsec 用户配置日志目录 ACL: ${log_dir}"
  fi
}

install_goaccess() {
  title "安装 GoAccess"
  if check_cmd goaccess; then
    ok "GoAccess 已安装。"
    return
  fi
  if [ "${PKG_MGR}" = "apt" ]; then
    show_exec_line "apt update && apt install -y goaccess jq curl cron"
    apt update
    apt install -y goaccess jq curl cron
  else
    show_exec_line "${PKG_MGR} install -y epel-release（可选）&& ${PKG_MGR} install -y goaccess jq curl cronie"
    ${PKG_MGR} install -y epel-release || true
    ${PKG_MGR} install -y goaccess jq curl cronie
  fi
  if check_cmd goaccess; then
    ok "GoAccess 安装完成。"
  else
    warn "GoAccess 安装失败，请检查仓库配置。"
  fi
}

# 系统是否已提供 zh_CN.UTF-8（GoAccess gettext 中文依赖此 locale）
locales_has_zh_cn_utf8() {
  locale -a 2>/dev/null | grep -qiE 'zh_CN\.(utf8|UTF-8)'
}

# Debian/Ubuntu：某 deb 是否处于已正确安装状态
dpkg_pkg_ok_installed() {
  dpkg -s "$1" 2>/dev/null | grep -q '^Status: install ok installed'
}

# 安装并生成 zh_CN.UTF-8（需 root；Debian/Ubuntu: locales；RHEL 系: glibc-langpack-zh 等）
install_locale_zh_cn_packages() {
  title "安装简体中文 locale（zh_CN.UTF-8）"
  if locales_has_zh_cn_utf8; then
    ok "locale zh_CN.UTF-8 已可用。"
    return 0
  fi
  detect_pkg_mgr
  if [ "${PKG_MGR}" = "apt" ]; then
    # locales 已安装时勿再 apt install：否则会触发 dpkg 配置其它待处理包（如半安装的 crowdsec bouncer），导致无关失败
    if dpkg_pkg_ok_installed locales; then
      info "软件包 locales 已安装，跳过 apt install，仅启用 locale.gen 并 locale-gen。"
    else
      show_exec_line "apt update && apt install -y locales"
      apt update && apt install -y locales
    fi
    if [ -f /etc/locale.gen ]; then
      sed -i 's/^#[[:space:]]*zh_CN.UTF-8 UTF-8/zh_CN.UTF-8 UTF-8/' /etc/locale.gen
      grep -qE '^zh_CN.UTF-8 UTF-8' /etc/locale.gen 2>/dev/null || echo "zh_CN.UTF-8 UTF-8" >> /etc/locale.gen
    fi
    show_exec_line "locale-gen zh_CN.UTF-8"
    if check_cmd locale-gen; then
      locale-gen zh_CN.UTF-8 2>/dev/null || locale-gen
    fi
  else
    show_exec_line "${PKG_MGR} install -y glibc-langpack-zh（或 langpacks）"
    ${PKG_MGR} install -y glibc-langpack-zh 2>/dev/null || \
      ${PKG_MGR} install -y langpacks-zh_CN 2>/dev/null || \
      ${PKG_MGR} install -y glibc-all-langpacks 2>/dev/null || \
      warn "未能自动安装中文 langpack，请手动安装 glibc-langpack-zh 或 langpacks-zh_CN。"
  fi
  if locales_has_zh_cn_utf8; then
    ok "locale zh_CN.UTF-8 已就绪。"
  else
    warn "仍未检测到 zh_CN.UTF-8，请执行 locale -a 排查。"
  fi
}

# 当 GOACCESS_LANG 为中文时，检查是否需要安装语言包（在「依赖检查与安装」中调用）
ensure_goaccess_locale_zh() {
  load_config
  case "${GOACCESS_LANG:-zh_CN}" in
    zh_CN|zh|zh_CN.UTF-8|zh.UTF-8) ;;
    *) return 0 ;;
  esac

  if locales_has_zh_cn_utf8; then
    ok "GoAccess 中文：zh_CN.UTF-8 locale 已就绪。"
    return 0
  fi

  warn "配置中 GOACCESS_LANG 为中文，但系统未检测到 zh_CN.UTF-8 locale。"
  info "GoAccess 中文界面依赖 LANG/LC_ALL=zh_CN.UTF-8（与 gettext 语言包），通常需安装 locales 或 glibc-langpack-zh。"
  info "是否安装中文语言包并生成 zh_CN.UTF-8？(y/n)"
  read -r _loc_ans
  if [ "${_loc_ans}" != "y" ]; then
    info "已跳过。可稍后以 root 再次执行本菜单安装。"
    return 0
  fi

  require_root
  detect_pkg_mgr
  install_locale_zh_cn_packages
}

install_crowdsec() {
  title "安装 CrowdSec 及 nftables Bouncer"
  if check_cmd cscli; then
    ok "CrowdSec 已安装。"
    return
  fi

  if [ "${PKG_MGR}" = "apt" ]; then
    show_exec_line "apt update && apt install -y curl gnupg lsb-release apt-transport-https（并配置 CrowdSec 仓库后安装 crowdsec 组件）"
    apt update
    apt install -y curl gnupg lsb-release apt-transport-https
    show_exec_line "curl ... crowdsec gpgkey | gpg --dearmor -o /usr/share/keyrings/crowdsec-archive-keyring.gpg"
    curl -fsSL https://packagecloud.io/crowdsec/crowdsec/gpgkey | gpg --dearmor -o /usr/share/keyrings/crowdsec-archive-keyring.gpg
    echo "deb [signed-by=/usr/share/keyrings/crowdsec-archive-keyring.gpg] https://packagecloud.io/crowdsec/crowdsec/ubuntu/ $(lsb_release -cs) main" > /etc/apt/sources.list.d/crowdsec.list
    apt update
    show_exec_line "apt install -y crowdsec crowdsec-firewall-bouncer-nftables nftables"
    apt install -y crowdsec crowdsec-firewall-bouncer-nftables nftables
  else
    show_exec_line "curl -s ... script.rpm.sh | bash && ${PKG_MGR} install -y crowdsec crowdsec-firewall-bouncer-nftables nftables"
    curl -s https://packagecloud.io/install/repositories/crowdsec/crowdsec/script.rpm.sh | bash
    ${PKG_MGR} install -y crowdsec crowdsec-firewall-bouncer-nftables nftables
  fi

  systemctl enable --now crowdsec >/dev/null 2>&1 || true
  systemctl enable --now crowdsec-firewall-bouncer >/dev/null 2>&1 || true

  if check_cmd cscli; then
    ok "CrowdSec 安装完成。"
  else
    warn "CrowdSec 安装失败，请手动排查。"
  fi
}

prompt_install_dependencies() {
  missing=""
  check_cmd goaccess || missing="${missing} goaccess"
  check_cmd cscli || missing="${missing} crowdsec"

  if [ -z "${missing}" ]; then
    ok "依赖检查通过。"
    ensure_goaccess_locale_zh
    return
  fi

  warn "发现缺失依赖:${missing}"
  info "是否执行一键逐步安装？(y/n)"
  read -r ans
  if [ "${ans}" != "y" ]; then
    warn "用户取消安装，部分功能不可用。"
    ensure_goaccess_locale_zh
    return
  fi

  require_root
  detect_pkg_mgr
  install_goaccess
  install_crowdsec

  load_config
  ports="${ALLOW_PORTS:-22,80,443}"
  info "防火墙端口提醒：请确保已放行 ${ports} 端口。"
  whitelist_self_ip
  ensure_goaccess_locale_zh
}

discover_log_dir() {
  load_config
  if [ -n "${LOG_DIR:-}" ] && [ -d "${LOG_DIR}" ]; then
    echo "${LOG_DIR}"
    return
  fi

  for d in /var/log/nginx /var/log/httpd; do
    if [ -d "${d}" ]; then
      save_kv "LOG_DIR" "${d}"
      ok "自动发现日志目录：${d}"
      echo "${d}"
      return
    fi
  done

  warn "未自动发现日志目录。"
  if [ -r /dev/tty ]; then
    echo "请输入日志目录（例如 /var/log/nginx）：" > /dev/tty
    read -r user_dir < /dev/tty
  else
    echo "请输入日志目录（例如 /var/log/nginx）："
    read -r user_dir
  fi
  if [ ! -d "${user_dir}" ]; then
    warn "目录不存在：${user_dir}"
    exit 1
  fi
  save_kv "LOG_DIR" "${user_dir}"
  ok "已保存日志目录：${user_dir}"
  echo "${user_dir}"
}

list_log_files() {
  log_dir="$1"
  ls -1 "${log_dir}"/*.log "${log_dir}"/*access*.log 2>/dev/null | awk '!seen[$0]++' || true
}

select_log_file() {
  log_dir="$1"
  files="$(list_log_files "${log_dir}")"
  if [ -z "${files}" ]; then
    warn "未找到日志文件，请检查目录：${log_dir}"
    exit 1
  fi
  if [ -r /dev/tty ]; then
    echo "${files}" | nl -w2 -s'. ' > /dev/tty
    echo "请选择日志文件序号：" > /dev/tty
    read -r idx < /dev/tty
  else
    # 兜底：非交互环境使用标准输入
    echo "${files}" | nl -w2 -s'. '
    echo "请选择日志文件序号："
    read -r idx
  fi
  selected="$(echo "${files}" | sed -n "${idx}p")"
  if [ -z "${selected}" ]; then
    warn "选择无效。"
    exit 1
  fi
  echo "${selected}"
}

# 是否与配置一致使用 GoAccess 简体中文界面（通过 LANG/LC_ALL，而非 --lang）
goaccess_wants_zh_ui() {
  load_config
  case "${GOACCESS_LANG:-zh_CN}" in
    zh_CN|zh|zh_CN.UTF-8|zh.UTF-8) return 0 ;;
    *) return 1 ;;
  esac
}

# 在子 shell 中注入 LANG/LC_ALL 后执行 slice | goaccess（与命令行 LANG=zh_CN.UTF-8 goaccess … 一致）
goaccess_pipe_from_slice() {
  _gm="$1"
  _gf="$2"
  shift 2
  if goaccess_wants_zh_ui; then
    (
      export LANG=zh_CN.UTF-8
      export LC_ALL=zh_CN.UTF-8
      slice_log_by_time "${_gm}" "${_gf}" | goaccess - "$@"
    )
  else
    slice_log_by_time "${_gm}" "${_gf}" | goaccess - "$@"
  fi
}

slice_log_by_time() {
  mode="$1"
  log_file="$2"

  # 将快捷时间选项统一换算为 epoch 区间，避免字符串比较导致误判
  now_epoch="$(date +%s)"
  start_epoch=""
  end_epoch=""

  if [ "${mode}" = "1h" ]; then
    start_epoch="$((now_epoch - 3600))"
    end_epoch="${now_epoch}"
  fi

  if [ "${mode}" = "today" ]; then
    today_start="$(date -d 'today 00:00:00' +%s 2>/dev/null || date -v0H -v0M -v0S +%s)"
    start_epoch="${today_start}"
    end_epoch="${now_epoch}"
  fi

  if [ "${mode}" = "yesterday" ]; then
    y_start="$(date -d 'yesterday 00:00:00' +%s 2>/dev/null || date -v-1d -v0H -v0M -v0S +%s)"
    y_end="$((y_start + 86400 - 1))"
    start_epoch="${y_start}"
    end_epoch="${y_end}"
  fi

  # custom: 20260401_000000-20260403_120000
  if [ -z "${start_epoch}" ] || [ -z "${end_epoch}" ]; then
    if ! echo "${mode}" | grep -Eq '^[0-9]{8}_[0-9]{6}-[0-9]{8}_[0-9]{6}$'; then
      warn "时间范围格式错误，应为：20260401_000000-20260403_120000"
      exit 1
    fi
    start_raw="${mode%-*}"
    end_raw="${mode#*-}"
    start_epoch="$(date -d "${start_raw:0:4}-${start_raw:4:2}-${start_raw:6:2} ${start_raw:9:2}:${start_raw:11:2}:${start_raw:13:2}" +%s 2>/dev/null || true)"
    end_epoch="$(date -d "${end_raw:0:4}-${end_raw:4:2}-${end_raw:6:2} ${end_raw:9:2}:${end_raw:11:2}:${end_raw:13:2}" +%s 2>/dev/null || true)"
    if [ -z "${start_epoch}" ] || [ -z "${end_epoch}" ]; then
      warn "无法解析时间范围。"
      exit 1
    fi
  fi

  if [ "${start_epoch}" -gt "${end_epoch}" ]; then
    warn "时间范围错误：开始时间不能晚于结束时间。"
    exit 1
  fi

  awk -v s="${start_epoch}" -v e="${end_epoch}" '
    BEGIN {
      mon["Jan"]=1; mon["Feb"]=2; mon["Mar"]=3; mon["Apr"]=4; mon["May"]=5; mon["Jun"]=6;
      mon["Jul"]=7; mon["Aug"]=8; mon["Sep"]=9; mon["Oct"]=10; mon["Nov"]=11; mon["Dec"]=12;
      local_epoch = systime();
      local_fmt = strftime("%Y %m %d %H %M %S", local_epoch);
      local_epoch_by_mktime = mktime(local_fmt);
      # local_tz_offset = 本地时区相对 UTC 的秒偏移（东区为正）
      local_tz_offset = local_epoch_by_mktime - local_epoch;
    }
    {
      # 匹配常见 Nginx/Apache 时间戳：[08/Apr/2026:17:21:33 +0800]
      if (match($0, /\[([0-9]{2})\/([A-Za-z]{3})\/([0-9]{4}):([0-9]{2}):([0-9]{2}):([0-9]{2})( [+-][0-9]{4})?\]/, a)) {
        epoch_local = mktime(a[3] " " mon[a[2]] " " a[1] " " a[4] " " a[5] " " a[6]);
        tz_seconds = local_tz_offset;
        # 若日志行自带时区偏移（如 +0800），则按该偏移换算为 UTC epoch
        if (a[7] != "") {
          sign = substr(a[7], 2, 1);
          hh = substr(a[7], 3, 2) + 0;
          mm = substr(a[7], 5, 2) + 0;
          z = (hh * 3600) + (mm * 60);
          if (sign == "-") {
            z = -z;
          }
          tz_seconds = z;
        }
        epoch = epoch_local + local_tz_offset - tz_seconds;
        if (epoch >= s && epoch <= e) {
          print $0;
        }
      }
    }
  ' "${log_file}"
}

# 抽样前若干行，判断 NPM/COMBINED 形态（用于选择 GoAccess 尝试顺序）
# 输出：combined | npm_standard | npm_proxy | unknown
# - combined：NCSA 行首为客户端 IP，时间戳在后方方括号内（如 default-host、部分 access）
# - npm_standard：] 后紧跟 三位状态码 - 方法（无 upstream 两段）
# - npm_proxy：] 后两段 upstream 再状态码 - 方法（官方 log_format proxy）
detect_goaccess_file_profile() {
  log_file="$1"
  n_combined=0
  n_std=0
  n_px=0
  while IFS= read -r line || [ -n "${line}" ]; do
    [ -z "${line}" ] && continue
    # COMBINED：行首不是 [，且含 [dd/Mon/yyyy:hh:mm:ss
    if ! echo "${line}" | grep -qE '^\[' && echo "${line}" | grep -qE '\[[0-9]{2}/[A-Za-z]{3}/[0-9]{4}:[0-9]{2}:[0-9]{2}:[0-9]{2}'; then
      n_combined=$((n_combined + 1))
      continue
    fi
    if ! echo "${line}" | grep -qE '^\[[0-9]{2}/[A-Za-z]{3}/[0-9]{4}:'; then
      continue
    fi
    # standard 先于 proxy 判断：] 200 - GET / PROPFIND …
    if echo "${line}" | grep -qE '\][[:space:]]+[0-9]{3}[[:space:]]+-[[:space:]]+[A-Za-z]'; then
      n_std=$((n_std + 1))
      continue
    fi
    # proxy：] token token 200 - METHOD
    if echo "${line}" | grep -qE '\][[:space:]]+[^ ]+[[:space:]]+[^ ]+[[:space:]]+[0-9]{3}[[:space:]]+-[[:space:]]+[A-Za-z]'; then
      n_px=$((n_px + 1))
    fi
  done < <(head -n 200 "${log_file}" 2>/dev/null || true)

  if [ "${n_combined}" -gt 0 ] && [ "${n_combined}" -ge "${n_std}" ] && [ "${n_combined}" -ge "${n_px}" ]; then
    echo "combined"
    return
  fi
  if [ "${n_px}" -gt "${n_std}" ]; then
    echo "npm_proxy"
    return
  fi
  if [ "${n_std}" -gt "${n_px}" ]; then
    echo "npm_standard"
    return
  fi
  if [ "${n_std}" -gt 0 ] || [ "${n_px}" -gt 0 ]; then
    # 数量相同（如 fallback 中 standard/proxy 混排）：先 standard，减少 proxy 模板错位
    echo "npm_standard"
    return
  fi
  echo "unknown"
}

# 按格式标识运行一次 goaccess（stdin 来自 slice_log_by_time；中文界面用 LANG/LC_ALL）
# 参数：mode log_file out_mode out_html format_id（combined|npm_proxy|npm_standard）
# 返回：goaccess 退出码
goaccess_run_slice() {
  mode="$1"
  log_file="$2"
  out_mode="$3"
  out_html="$4"
  format_id="$5"

  _ga_pfx=""
  if goaccess_wants_zh_ui; then
    _ga_pfx="LANG=zh_CN.UTF-8 LC_ALL=zh_CN.UTF-8 "
  fi

  set +e
  _ga_rc=1
  case "${format_id}" in
    combined)
      if [ "${out_mode}" = "term" ]; then
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format=COMBINED --date-format=%d/%b/%Y --time-format=%H:%M:%S"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format=COMBINED \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S
      else
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format=COMBINED --date-format=%d/%b/%Y --time-format=%H:%M:%S --output=${out_html}"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format=COMBINED \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S \
          --output="${out_html}"
      fi
      _ga_rc=$?
      ;;
    npm_proxy)
      if [ "${out_mode}" = "term" ]; then
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format='${GOACCESS_NPM_LOG_FORMAT}' --date-format=%d/%b/%Y --time-format=%H:%M:%S"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format="${GOACCESS_NPM_LOG_FORMAT}" \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S
      else
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format='${GOACCESS_NPM_LOG_FORMAT}' --date-format=%d/%b/%Y --time-format=%H:%M:%S --output=${out_html}"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format="${GOACCESS_NPM_LOG_FORMAT}" \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S \
          --output="${out_html}"
      fi
      _ga_rc=$?
      ;;
    npm_standard)
      if [ "${out_mode}" = "term" ]; then
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format='${GOACCESS_NPM_LOG_FORMAT_ALT}' --date-format=%d/%b/%Y --time-format=%H:%M:%S"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format="${GOACCESS_NPM_LOG_FORMAT_ALT}" \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S
      else
        ga_cmd="${_ga_pfx}slice_log_by_time ${mode} ${log_file} | goaccess - --log-format='${GOACCESS_NPM_LOG_FORMAT_ALT}' --date-format=%d/%b/%Y --time-format=%H:%M:%S --output=${out_html}"
        show_exec_line "${ga_cmd}"
        goaccess_pipe_from_slice "${mode}" "${log_file}" \
          --log-format="${GOACCESS_NPM_LOG_FORMAT_ALT}" \
          --date-format=%d/%b/%Y \
          --time-format=%H:%M:%S \
          --output="${out_html}"
      fi
      _ga_rc=$?
      ;;
    *)
      _ga_rc=1
      ;;
  esac
  set -e
  return "${_ga_rc}"
}

goaccess_report() {
  if ! check_cmd goaccess; then
    warn "GoAccess 未安装。"
    return
  fi

  # discover_log_dir 可能输出提示信息，取最后一行作为真实路径
  log_dir="$(discover_log_dir | awk 'END{print}')"
  log_file="$(select_log_file "${log_dir}")"

  if [ -r /dev/tty ]; then
    title "日志格式（GoAccess）" > /dev/tty
    echo "1) 通用 COMBINED（Nginx/Apache 默认 access）" > /dev/tty
    echo "2) Nginx Proxy Manager（proxy 自定义：%v 域名、[Client %h] 客户端 IP）" > /dev/tty
    echo "3) 自动检测（抽样前 200 行：NCSA / NPM proxy / standard）" > /dev/tty
    echo "请选择：" > /dev/tty
    read -r fmt_sel < /dev/tty
  else
    title "日志格式（GoAccess）"
    echo "1) 通用 COMBINED（Nginx/Apache 默认 access）"
    echo "2) Nginx Proxy Manager（proxy 自定义：%v 域名、[Client %h] 客户端 IP）"
    echo "3) 自动检测（抽样前 200 行：NCSA / NPM proxy / standard）"
    echo "请选择："
    read -r fmt_sel
  fi

  use_npm=0
  case "${fmt_sel}" in
    1) use_npm=0 ;;
    2) use_npm=1 ;;
    3)
      _auto_prof="$(detect_goaccess_file_profile "${log_file}")"
      if [ "${_auto_prof}" = "combined" ]; then
        use_npm=0
        info "自动检测：前 200 行为 NCSA/COMBINED（行首为客户端 IP），仅用 COMBINED。"
      else
        use_npm=1
        info "自动检测：前 200 行形态「${_auto_prof}」，使用 NPM 解析链（失败时回退 COMBINED）。"
      fi
      ;;
    *)
      warn "无效选择，已回退为 COMBINED。"
      use_npm=0
      ;;
  esac

  if [ -r /dev/tty ]; then
    title "选择时间切片" > /dev/tty
    echo "1) 过去 1 小时" > /dev/tty
    echo "2) 今天" > /dev/tty
    echo "3) 昨天" > /dev/tty
    echo "4) 自定义范围（20260401_000000-20260403_120000）" > /dev/tty
    echo "请选择：" > /dev/tty
    read -r tsel < /dev/tty
  else
    title "选择时间切片"
    echo "1) 过去 1 小时"
    echo "2) 今天"
    echo "3) 昨天"
    echo "4) 自定义范围（20260401_000000-20260403_120000）"
    echo "请选择："
    read -r tsel
  fi

  mode=""
  case "${tsel}" in
    1) mode="1h" ;;
    2) mode="today" ;;
    3) mode="yesterday" ;;
    4)
      if [ -r /dev/tty ]; then
        echo "请输入时间范围：" > /dev/tty
        read -r mode < /dev/tty
      else
        echo "请输入时间范围："
        read -r mode
      fi
      ;;
    *) warn "无效选择"; return ;;
  esac

  out_html="/tmp/goaccess-report-$(date +%Y%m%d%H%M%S).html"
  load_config
  if goaccess_wants_zh_ui && ! locales_has_zh_cn_utf8; then
    info "未检测到 zh_CN.UTF-8 locale，GoAccess 可能仍显示英文；可在主菜单「1) 依赖检查与安装」生成中文 locale。"
  fi

  if [ -r /dev/tty ]; then
    title "输出方式（GoAccess）" > /dev/tty
    echo "1) 终端查看（交互模式，按 q 退出）" > /dev/tty
    echo "2) 生成静态 HTML（推荐）" > /dev/tty
    echo "请选择：" > /dev/tty
    read -r out_sel < /dev/tty
  else
    title "输出方式（GoAccess）"
    echo "1) 终端查看（交互模式，按 q 退出）"
    echo "2) 生成静态 HTML（推荐）"
    echo "请选择："
    read -r out_sel
  fi

  out_mode="html"
  case "${out_sel}" in
    1) out_mode="term" ;;
    2) out_mode="html" ;;
    *) warn "无效选择，已回退为静态 HTML。"; out_mode="html" ;;
  esac

  ga_ret=1
  if [ "${use_npm}" -eq 1 ]; then
    profile="$(detect_goaccess_file_profile "${log_file}")"
    info "GoAccess：前 200 行抽样为「${profile}」，将按序尝试（含 COMBINED 兜底）。"
    case "${profile}" in
      combined)
        try_list="combined"
        ;;
      npm_standard)
        try_list="npm_standard npm_proxy combined"
        ;;
      npm_proxy)
        try_list="npm_proxy npm_standard combined"
        ;;
      *)
        try_list="npm_proxy npm_standard combined"
        ;;
    esac
    set +e
    for fmt in ${try_list}; do
      case "${fmt}" in
        combined) _ga_label="COMBINED（NCSA）" ;;
        npm_proxy) _ga_label="NPM proxy" ;;
        npm_standard) _ga_label="NPM standard" ;;
        *) _ga_label="${fmt}" ;;
      esac
      info "尝试格式：${_ga_label}"
      goaccess_run_slice "${mode}" "${log_file}" "${out_mode}" "${out_html}" "${fmt}"
      ga_ret=$?
      [ "${ga_ret}" -eq 0 ] && break
      _try_last="$(echo "${try_list}" | awk '{print $NF}')"
      [ "${fmt}" != "${_try_last}" ] && info "本格式未成功，尝试下一种…"
    done
    set -e
  else
    set +e
    goaccess_run_slice "${mode}" "${log_file}" "${out_mode}" "${out_html}" "combined"
    ga_ret=$?
    set -e
  fi

  if [ "${ga_ret}" -eq 0 ]; then
    if [ "${out_mode}" = "html" ]; then
      ok "静态 HTML 报告生成成功：${out_html}"
    else
      ok "终端统计已结束。"
    fi
  else
    warn "GoAccess 执行失败。"
  fi
}

