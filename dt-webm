normalize_ports() {
  raw="$1"
  cleaned="$(echo "${raw}" | tr -d ' ')"
  if [ -z "${cleaned}" ]; then
    return 1
  fi

  IFS=',' read -r -a arr <<< "${cleaned}"
  out=""
  for p in "${arr[@]}"; do
    if ! echo "${p}" | grep -Eq '^[0-9]+$'; then
      return 1
    fi
    if [ "${p}" -lt 1 ] || [ "${p}" -gt 65535 ]; then
      return 1
    fi
    if [ -z "${out}" ]; then
      out="${p}"
    else
      case ",${out}," in
        *,"${p}",*) ;;
        *) out="${out},${p}" ;;
      esac
    fi
  done
  echo "${out}"
}

