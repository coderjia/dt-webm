main() {
  detect_pkg_mgr
  ensure_config
  ensure_default_config_values

  case "${1:-}" in
    install) do_install_cmd; exit 0 ;;
    geoip-update) update_geoip_db; exit 0 ;;
    metrics) show_cscli_metrics; exit 0 ;;
    self-update) self_update_dt_webm; exit 0 ;;
    "")
      :
      ;;
    *)
      warn "未知命令：$1"
      echo "用法：dt-webm [install|geoip-update|metrics|self-update]"
      exit 1
      ;;
  esac

  while true; do
    show_main_menu
    read -r sel
    case "${sel}" in
      1) prompt_install_dependencies ;;
      2) goaccess_report ;;
      3) show_alerts ;;
      4) show_cscli_metrics ;;
      5) manage_decisions ;;
      6) configure_webhook ;;
      7) configure_allow_ports ;;
      8) update_geoip_db ;;
      9) setup_geoip_cron ;;
      10) setup_alert_push_cron ;;
      11) do_install_cmd ;;
      12) self_update_dt_webm ;;
      0) ok "已退出。"; exit 0 ;;
      *) warn "无效选择，请重试。" ;;
    esac
    echo
  done
}

